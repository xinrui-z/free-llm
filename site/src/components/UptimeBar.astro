---
interface Props {
  days: string[];
  label?: string;
  showLabels?: boolean;
  windowDays?: number; // total days the bar should span (pads left with 'unknown')
}

const { days, label, showLabels = false, windowDays } = Astro.props;

// Pad to windowDays if provided: fill missing leading days with 'unknown'
const paddedDays = windowDays && days.length < windowDays
  ? [...Array(windowDays - days.length).fill('unknown'), ...days]
  : days;

const displayWindowLabel = windowDays ?? paddedDays.length;

const colorMap: Record<string, string> = {
  active:   'bg-green-500',
  degraded: 'bg-yellow-500',
  dead:     'bg-red-500',
  unknown:  'bg-slate-700 opacity-40',
};

function getColor(status: string): string {
  return colorMap[status] ?? colorMap.unknown;
}

// Calculate uptime stats (exclude 'unknown' days from denominator)
const knownDays = paddedDays.filter(d => d !== 'unknown');
const total = knownDays.length;
const activeCount = paddedDays.filter(d => d === 'active').length;
const degradedCount = paddedDays.filter(d => d === 'degraded').length;
const deadCount = paddedDays.filter(d => d === 'dead').length;
const uptimePct = total > 0 ? ((activeCount / total) * 100).toFixed(1) : '0.0';

// Generate tooltips
const today = new Date();
const dayLabels = paddedDays.map((_, i) => {
  const d = new Date(today);
  d.setDate(d.getDate() - (paddedDays.length - 1 - i));
  return d.toISOString().split('T')[0];
});
---

<div class="w-full">
  {label && <p class="text-xs text-slate-500 mb-1">{label}</p>}

  <!-- Bar -->
  <div class="flex gap-px items-end h-6 w-full overflow-hidden">
    {paddedDays.map((status, i) => (
      <div
        class={`flex-1 min-w-0 rounded-sm cursor-pointer transition-all duration-150 hover:brightness-125 ${getColor(status)}`}
        style="height: 20px"
        title={`${dayLabels[i]}: ${status}`}
        data-date={dayLabels[i]}
        data-status={status}
      ></div>
    ))}
  </div>

  {showLabels && (
    <div class="flex justify-between mt-1">
      <span class="text-xs text-slate-600">{displayWindowLabel}d ago</span>
      <span class="text-xs text-slate-600">today</span>
    </div>
    <div class="mt-1 flex flex-wrap gap-2 text-xs">
      <span class="text-green-400 font-mono">{uptimePct}% uptime</span>
      {deadCount > 0 && <span class="text-red-400 font-mono">{deadCount} outage{deadCount > 1 ? 's' : ''}</span>}
      {degradedCount > 0 && <span class="text-yellow-400 font-mono">{degradedCount} degraded</span>}
    </div>
  )}
</div>
