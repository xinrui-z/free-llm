---
import Layout from '../../layouts/Layout.astro';
import providers from '../../data/providers.json';

const providersJson = JSON.stringify(providers.map(p => ({ id: p.id, name: p.name, logo: p.logo, status: p.status })));
const workerUrl = import.meta.env.PUBLIC_STATUS_WORKER_URL ?? '';
---

<Layout
  title="Alerts & Subscriptions — Free LLM APIs"
  description="Subscribe to alerts for free LLM API providers. Get notified by email or webhook when providers go down or experience degraded performance."
>
  <div class="max-w-4xl mx-auto px-4 md:px-6 lg:px-8 py-8">

    <!-- Page header -->
    <div class="flex items-start justify-between mb-8">
      <div>
        <h1 class="text-2xl font-bold text-white mb-1">Alerts</h1>
        <p class="text-slate-400 text-sm">Get notified when providers go down or degrade. Delivered via email or webhook.</p>
      </div>
      <button
        id="new-subscription-btn"
        class="flex items-center gap-2 px-4 py-2 bg-indigo-600 hover:bg-indigo-500 text-white rounded-lg text-sm font-medium transition-all duration-150 shadow-lg shadow-indigo-500/20"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="12" y1="5" x2="12" y2="19"></line>
          <line x1="5" y1="12" x2="19" y2="12"></line>
        </svg>
        New Subscription
      </button>
    </div>

    <!-- Subscription list -->
    <div id="subscription-list">
      <!-- Populated by JS -->
    </div>

    <!-- Empty state (shown when no subscriptions) -->
    <div id="empty-state" class="hidden flex flex-col items-center justify-center py-20 text-center">
      <div class="w-16 h-16 rounded-2xl bg-slate-800 border border-slate-700 flex items-center justify-center mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-slate-500">
          <path d="M13.73 21a2 2 0 0 1-3.46 0"></path>
          <path d="M18.63 13A17.89 17.89 0 0 1 18 8"></path>
          <path d="M6.26 6.26A5.86 5.86 0 0 0 6 8c0 7-3 9-3 9h14"></path>
          <path d="M18 8a6 6 0 0 0-9.33-5"></path>
          <line x1="1" y1="1" x2="23" y2="23"></line>
        </svg>
      </div>
      <h2 class="text-lg font-semibold text-slate-200 mb-1">No subscriptions yet</h2>
      <p class="text-slate-500 text-sm mb-6 max-w-xs">Create your first alert subscription to get notified when a provider goes down or degrades.</p>
      <button
        class="trigger-new-subscription flex items-center gap-2 px-4 py-2 bg-indigo-600 hover:bg-indigo-500 text-white rounded-lg text-sm font-medium transition-all duration-150"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="12" y1="5" x2="12" y2="19"></line>
          <line x1="5" y1="12" x2="19" y2="12"></line>
        </svg>
        New Subscription
      </button>
    </div>
  </div>

  <!-- ════════════════════════════════════════════════════════════════
       Multi-step Modal
  ════════════════════════════════════════════════════════════════ -->
  <div id="modal-overlay" class="fixed inset-0 z-50 bg-black/60 backdrop-blur-sm hidden flex items-center justify-center p-4">
    <div id="modal-box" class="relative bg-slate-900 border border-slate-700 rounded-2xl shadow-2xl w-full max-w-lg">

      <!-- Modal header -->
      <div class="flex items-center justify-between px-6 pt-6 pb-4 border-b border-slate-800">
        <h2 class="text-lg font-semibold text-white" id="modal-title">New Subscription</h2>
        <button id="modal-close" class="text-slate-500 hover:text-slate-300 transition-colors duration-150 p-1">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
      </div>

      <!-- Step indicator -->
      <div class="flex items-center justify-center gap-2 px-6 py-4" id="step-indicator">
        {[1, 2, 3].map(n => (
          <div class="flex items-center gap-2">
            <div
              class={`w-7 h-7 rounded-full flex items-center justify-center text-xs font-semibold transition-all duration-200 step-dot`}
              data-step={n}
            >
              {n}
            </div>
            {n < 3 && <div class={`w-10 h-px step-line`} data-after={n}></div>}
          </div>
        ))}
      </div>

      <!-- Step content -->
      <div class="px-6 pb-6">

        <!-- Step 1: Channel -->
        <div id="step-1" class="step-panel">
          <h3 class="text-sm font-semibold text-slate-200 mb-3">How would you like to be notified?</h3>
          <div class="grid grid-cols-2 gap-3 mb-4">
            <button
              class="channel-opt flex flex-col items-center gap-2 p-4 rounded-xl border border-slate-700 bg-slate-800 hover:border-indigo-500/50 transition-all duration-150"
              data-channel="email"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-slate-400">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                <polyline points="22,6 12,13 2,6"></polyline>
              </svg>
              <span class="text-sm font-medium text-slate-300">Email</span>
            </button>
            <button
              class="channel-opt flex flex-col items-center gap-2 p-4 rounded-xl border border-slate-700 bg-slate-800 hover:border-indigo-500/50 transition-all duration-150"
              data-channel="webhook"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-slate-400">
                <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path>
                <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path>
              </svg>
              <span class="text-sm font-medium text-slate-300">Webhook</span>
            </button>
          </div>

          <div id="channel-address-wrap" class="hidden">
            <label class="block text-xs text-slate-400 mb-1.5" id="channel-address-label">Email address</label>
            <input
              id="channel-address"
              type="text"
              placeholder=""
              class="w-full bg-slate-700 rounded-lg border border-slate-600 focus:border-indigo-500 focus:outline-none px-3 py-2 text-sm text-slate-100 placeholder-slate-500"
            />
          </div>
        </div>

        <!-- Step 2: Providers -->
        <div id="step-2" class="step-panel hidden">
          <h3 class="text-sm font-semibold text-slate-200 mb-3">Select providers to watch</h3>
          <input
            id="provider-filter"
            type="text"
            placeholder="Search providers…"
            class="w-full bg-slate-700 rounded-lg border border-slate-600 focus:border-indigo-500 focus:outline-none px-3 py-2 text-sm text-slate-100 placeholder-slate-500 mb-3"
          />
          <div id="provider-select-list" class="max-h-52 overflow-y-auto space-y-1 pr-1"></div>
          <p id="provider-select-hint" class="mt-2 text-xs text-slate-500"></p>
        </div>

        <!-- Step 3: Alert level + confirmation -->
        <div id="step-3" class="step-panel hidden">
          <h3 class="text-sm font-semibold text-slate-200 mb-3">Alert level</h3>

          <div class="space-y-2 mb-5">
            <label class="flex items-start gap-3 p-3 rounded-xl border border-slate-700 bg-slate-800 cursor-pointer hover:border-slate-600 transition-all duration-150">
              <input type="radio" name="alert-level" value="dead" class="mt-0.5 accent-indigo-500" />
              <div>
                <p class="text-sm font-medium text-slate-200">Dead only</p>
                <p class="text-xs text-slate-500 mt-0.5">Notify only when a provider is fully down.</p>
              </div>
            </label>
            <label class="flex items-start gap-3 p-3 rounded-xl border border-slate-700 bg-slate-800 cursor-pointer hover:border-slate-600 transition-all duration-150">
              <input type="radio" name="alert-level" value="degraded" class="mt-0.5 accent-indigo-500" checked />
              <div>
                <p class="text-sm font-medium text-slate-200">Degraded + Dead</p>
                <p class="text-xs text-slate-500 mt-0.5">Notify on any issue — degraded performance or full outage.</p>
              </div>
            </label>
          </div>

          <!-- Summary -->
          <div id="step3-summary" class="bg-slate-800/60 border border-slate-700 rounded-xl p-4 text-sm space-y-2 mb-2">
            <div class="flex justify-between">
              <span class="text-slate-500">Channel</span>
              <span id="summary-channel" class="text-slate-200 font-medium"></span>
            </div>
            <div class="flex justify-between">
              <span class="text-slate-500">Destination</span>
              <span id="summary-address" class="text-slate-200 font-mono text-xs truncate max-w-[200px]"></span>
            </div>
            <div class="flex justify-between">
              <span class="text-slate-500">Providers</span>
              <span id="summary-providers" class="text-slate-200 text-right"></span>
            </div>
          </div>
        </div>

        <!-- Success state -->
        <div id="step-success" class="hidden text-center py-6">
          <div class="w-14 h-14 rounded-full bg-green-500/20 border border-green-500/30 flex items-center justify-center mx-auto mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-green-400">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-white mb-1">Subscription created!</h3>
          <p class="text-sm text-slate-400">You'll be notified when the selected providers change status.</p>
        </div>
      </div>

      <!-- Modal footer -->
      <div class="flex items-center justify-between px-6 pb-6" id="modal-footer">
        <button id="modal-back" class="px-4 py-2 text-sm text-slate-400 hover:text-slate-200 transition-colors duration-150 hidden">
          Back
        </button>
        <div class="flex gap-2 ml-auto">
          <button id="modal-cancel" class="px-4 py-2 text-sm text-slate-400 hover:text-slate-200 bg-slate-800 hover:bg-slate-700 border border-slate-700 rounded-lg transition-all duration-150">
            Cancel
          </button>
          <button id="modal-next" class="px-4 py-2 text-sm text-white bg-indigo-600 hover:bg-indigo-500 rounded-lg transition-all duration-150 font-medium">
            Next
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Delete confirmation Dialog -->
  <div id="delete-overlay" class="fixed inset-0 z-50 bg-black/60 backdrop-blur-sm hidden flex items-center justify-center p-4">
    <div class="bg-slate-900 border border-slate-700 rounded-2xl shadow-2xl w-full max-w-sm p-6">
      <h2 class="text-base font-semibold text-white mb-2">Delete Subscription?</h2>
      <p class="text-sm text-slate-400 mb-5">This will permanently remove this alert subscription. You won't receive further notifications for this subscription.</p>
      <div class="flex gap-3 justify-end">
        <button id="delete-cancel" class="px-4 py-2 text-sm text-slate-400 hover:text-slate-200 bg-slate-800 hover:bg-slate-700 border border-slate-700 rounded-lg transition-all duration-150">
          Cancel
        </button>
        <button id="delete-confirm" class="px-4 py-2 text-sm text-white bg-red-600 hover:bg-red-500 rounded-lg transition-all duration-150 font-medium">
          Delete
        </button>
      </div>
    </div>
  </div>
</Layout>

<script define:vars={{ providersJson, workerUrl }}>
  const ALL_PROVIDERS = JSON.parse(providersJson);
  const LS_KEY = 'alert-subscriptions';
  const WORKER_URL = workerUrl;

  // ── State ──────────────────────────────────────────────────────────────────
  let modalStep = 1;
  let formState = {
    channel: '',
    address: '',
    selectedProviders: [],
    alertLevel: 'degraded',
  };
  let deleteTargetId = null;

  // ── LocalStorage (local cache) ────────────────────────────────────────────
  function getSubscriptions() {
    try { return JSON.parse(localStorage.getItem(LS_KEY) || '[]'); }
    catch { return []; }
  }

  function saveSubscriptions(subs) {
    localStorage.setItem(LS_KEY, JSON.stringify(subs));
  }

  // ── API helpers ───────────────────────────────────────────────────────────
  async function apiCreateSubscription(sub) {
    if (!WORKER_URL) return { ok: true, id: sub.id }; // offline mode
    const resp = await fetch(`${WORKER_URL}/api/subscriptions`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        channel: sub.channel,
        address: sub.address,
        providers: sub.providers,
        alertLevel: sub.alertLevel,
      }),
    });
    if (!resp.ok) throw new Error(`API error ${resp.status}`);
    return resp.json();
  }

  async function apiDeleteSubscription(id) {
    if (!WORKER_URL) return; // offline mode
    await fetch(`${WORKER_URL}/api/subscriptions/${id}`, { method: 'DELETE' });
  }

  // ── Subscription list rendering ─────────────────────────────────────────
  function renderSubscriptions() {
    const subs = getSubscriptions();
    const list = document.getElementById('subscription-list');
    const empty = document.getElementById('empty-state');
    if (!list || !empty) return;

    if (subs.length === 0) {
      list.innerHTML = '';
      empty.classList.remove('hidden');
      return;
    }

    empty.classList.add('hidden');

    list.innerHTML = subs.map(sub => {
      const providerNames = (sub.providers || [])
        .map(id => ALL_PROVIDERS.find(p => p.id === id)?.name ?? id)
        .join(', ');
      const channelIcon = sub.channel === 'email'
        ? `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>`
        : `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path></svg>`;

      const levelBadge = sub.alertLevel === 'dead'
        ? '<span class="px-2 py-0.5 bg-red-500/10 border border-red-500/20 text-red-400 rounded-full text-xs font-mono">dead only</span>'
        : '<span class="px-2 py-0.5 bg-amber-500/10 border border-amber-500/20 text-amber-400 rounded-full text-xs font-mono">degraded+dead</span>';

      const createdAt = sub.createdAt
        ? new Date(sub.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })
        : 'Unknown date';

      return `
        <div class="bg-slate-800 border border-slate-700 rounded-xl p-4 mb-3 hover:border-slate-600 transition-all duration-150" data-sub-id="${sub.id}">
          <div class="flex items-start justify-between gap-3">
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-2">
                <span class="text-slate-400">${channelIcon}</span>
                <span class="text-sm font-mono text-slate-200 truncate">${sub.address}</span>
                ${levelBadge}
              </div>
              <p class="text-xs text-slate-500 truncate">
                <span class="text-slate-400">Watching:</span> ${providerNames || 'No providers'}
              </p>
              <p class="text-xs text-slate-600 mt-1">${createdAt}</p>
            </div>
            <button
              class="delete-sub-btn flex-shrink-0 p-2 text-slate-600 hover:text-red-400 transition-colors duration-150 rounded-lg hover:bg-red-500/10"
              data-sub-id="${sub.id}"
              aria-label="Delete subscription"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="3 6 5 6 21 6"></polyline>
                <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"></path>
                <path d="M10 11v6"></path>
                <path d="M14 11v6"></path>
                <path d="M9 6V4h6v2"></path>
              </svg>
            </button>
          </div>
        </div>
      `;
    }).join('');

    // Bind delete buttons
    list.querySelectorAll('.delete-sub-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        deleteTargetId = btn.getAttribute('data-sub-id');
        document.getElementById('delete-overlay')?.classList.remove('hidden');
      });
    });
  }

  // ── Step indicator ─────────────────────────────────────────────────────────
  function updateStepUI(step) {
    document.querySelectorAll('.step-dot').forEach(dot => {
      const n = parseInt(dot.getAttribute('data-step') || '0');
      if (n < step) {
        dot.className = 'w-7 h-7 rounded-full flex items-center justify-center text-xs font-semibold transition-all duration-200 step-dot bg-indigo-600 text-white';
      } else if (n === step) {
        dot.className = 'w-7 h-7 rounded-full flex items-center justify-center text-xs font-semibold transition-all duration-200 step-dot bg-indigo-500 text-white ring-2 ring-indigo-500/30';
      } else {
        dot.className = 'w-7 h-7 rounded-full flex items-center justify-center text-xs font-semibold transition-all duration-200 step-dot bg-slate-700 text-slate-400';
      }
    });
    document.querySelectorAll('.step-line').forEach(line => {
      const n = parseInt(line.getAttribute('data-after') || '0');
      line.className = `w-10 h-px step-line transition-all duration-200 ${n < step ? 'bg-indigo-500' : 'bg-slate-700'}`;
    });
  }

  // ── Modal open/close ─────────────────────────────────────────────────────
  function openModal() {
    modalStep = 1;
    formState = { channel: '', address: '', selectedProviders: [], alertLevel: 'degraded' };
    showStep(1);
    document.getElementById('modal-overlay')?.classList.remove('hidden');
    document.getElementById('step-indicator')?.classList.remove('hidden');
    document.getElementById('modal-footer')?.classList.remove('hidden');
    document.getElementById('step-success')?.classList.add('hidden');
    document.getElementById('modal-next')!.textContent = 'Next';
    document.getElementById('modal-title')!.textContent = 'New Subscription';
    updateStepUI(1);
    resetChannelSelection();
  }

  function closeModal() {
    document.getElementById('modal-overlay')?.classList.add('hidden');
  }

  function showStep(n) {
    [1, 2, 3].forEach(i => {
      const el = document.getElementById(`step-${i}`);
      if (el) el.classList.toggle('hidden', i !== n);
    });
    const backBtn = document.getElementById('modal-back');
    if (backBtn) backBtn.classList.toggle('hidden', n === 1);
    updateStepUI(n);
  }

  function resetChannelSelection() {
    document.querySelectorAll('.channel-opt').forEach(opt => {
      opt.classList.remove('border-indigo-500', 'bg-indigo-500/10');
      opt.classList.add('border-slate-700', 'bg-slate-800');
    });
    document.getElementById('channel-address-wrap')?.classList.add('hidden');
    const input = document.getElementById('channel-address');
    if (input) input.value = '';
  }

  // ── Provider selection list ─────────────────────────────────────────────
  function renderProviderSelectList(filter = '') {
    const container = document.getElementById('provider-select-list');
    const hint = document.getElementById('provider-select-hint');
    if (!container) return;

    const lower = filter.toLowerCase();
    const visible = ALL_PROVIDERS.filter(p =>
      p.name.toLowerCase().includes(lower) || p.id.includes(lower)
    );

    container.innerHTML = visible.map(p => {
      const checked = formState.selectedProviders.includes(p.id);
      return `
        <label class="flex items-center gap-3 p-2.5 rounded-lg cursor-pointer hover:bg-slate-700/50 transition-colors duration-100">
          <input
            type="checkbox"
            value="${p.id}"
            class="provider-checkbox w-4 h-4 accent-indigo-500 flex-shrink-0"
            ${checked ? 'checked' : ''}
          />
          <div class="w-6 h-6 rounded bg-slate-700 flex items-center justify-center text-xs font-bold text-slate-300 flex-shrink-0 overflow-hidden">
            ${p.logo
              ? `<img src="${p.logo}" alt="${p.name}" class="w-full h-full object-contain brightness-0 invert" onerror="this.style.display='none'">`
              : p.name.charAt(0)}
          </div>
          <span class="text-sm text-slate-200">${p.name}</span>
          <span class="ml-auto text-xs font-mono ${p.status === 'active' ? 'text-green-400' : p.status === 'degraded' ? 'text-amber-400' : 'text-red-400'}">${p.status}</span>
        </label>
      `;
    }).join('');

    container.querySelectorAll('.provider-checkbox').forEach(cb => {
      cb.addEventListener('change', () => {
        const id = cb.value;
        if (cb.checked) {
          if (!formState.selectedProviders.includes(id)) formState.selectedProviders.push(id);
        } else {
          formState.selectedProviders = formState.selectedProviders.filter(x => x !== id);
        }
        if (hint) hint.textContent = formState.selectedProviders.length > 0
          ? `${formState.selectedProviders.length} provider${formState.selectedProviders.length > 1 ? 's' : ''} selected`
          : '';
      });
    });
  }

  // ── Navigation ──────────────────────────────────────────────────────────
  function validateStep(step) {
    if (step === 1) {
      if (!formState.channel) {
        alert('Please select a notification channel.');
        return false;
      }
      if (!formState.address.trim()) {
        alert(`Please enter ${formState.channel === 'email' ? 'an email address' : 'a webhook URL'}.`);
        return false;
      }
    }
    if (step === 2) {
      if (formState.selectedProviders.length === 0) {
        alert('Please select at least one provider to watch.');
        return false;
      }
    }
    return true;
  }

  function goNext() {
    if (!validateStep(modalStep)) return;

    if (modalStep < 3) {
      modalStep++;
      showStep(modalStep);

      if (modalStep === 2) {
        renderProviderSelectList('');
        document.getElementById('provider-filter')?.addEventListener('input', e => {
          renderProviderSelectList(e.target.value);
        });
      }

      if (modalStep === 3) {
        // Populate summary
        const levelVal = document.querySelector('input[name="alert-level"]:checked')?.value ?? 'degraded';
        formState.alertLevel = levelVal;
        document.getElementById('summary-channel').textContent = formState.channel.charAt(0).toUpperCase() + formState.channel.slice(1);
        document.getElementById('summary-address').textContent = formState.address;
        const names = formState.selectedProviders
          .map(id => ALL_PROVIDERS.find(p => p.id === id)?.name ?? id)
          .join(', ');
        document.getElementById('summary-providers').textContent = names;
        document.getElementById('modal-next').textContent = 'Create Subscription';
      }
    } else {
      // Finalize — submit to Worker API
      formState.alertLevel = document.querySelector('input[name="alert-level"]:checked')?.value ?? 'degraded';

      const nextBtn = document.getElementById('modal-next');
      if (nextBtn) { nextBtn.textContent = 'Saving…'; nextBtn.setAttribute('disabled', 'true'); }

      const localSub = {
        id: crypto.randomUUID?.() ?? Date.now().toString(),
        channel: formState.channel,
        address: formState.address,
        providers: formState.selectedProviders,
        alertLevel: formState.alertLevel,
        createdAt: new Date().toISOString(),
      };

      try {
        const result = await apiCreateSubscription(localSub);
        // Use server-generated ID if available
        const finalSub = { ...localSub, id: result.id ?? localSub.id };
        const subs = getSubscriptions();
        subs.push(finalSub);
        saveSubscriptions(subs);

        // Show success
        [1, 2, 3].forEach(i => document.getElementById(`step-${i}`)?.classList.add('hidden'));
        document.getElementById('step-success')?.classList.remove('hidden');
        document.getElementById('step-indicator')?.classList.add('hidden');
        document.getElementById('modal-footer')?.classList.add('hidden');
        document.getElementById('modal-title').textContent = '';

        setTimeout(() => {
          closeModal();
          renderSubscriptions();
        }, 1800);
      } catch (err) {
        console.error('[alerts] create failed:', err);
        if (nextBtn) { nextBtn.textContent = 'Create Subscription'; nextBtn.removeAttribute('disabled'); }
        alert('Failed to save subscription. Please check your connection and try again.');
      }
    }
  }

  function goBack() {
    if (modalStep > 1) {
      modalStep--;
      showStep(modalStep);
      document.getElementById('modal-next').textContent = modalStep === 3 ? 'Create Subscription' : 'Next';
    }
  }

  // ── Bind events ─────────────────────────────────────────────────────────
  // Open modal buttons
  document.getElementById('new-subscription-btn')?.addEventListener('click', openModal);
  document.querySelector('.trigger-new-subscription')?.addEventListener('click', openModal);

  // Close
  document.getElementById('modal-close')?.addEventListener('click', closeModal);
  document.getElementById('modal-cancel')?.addEventListener('click', closeModal);
  document.getElementById('modal-overlay')?.addEventListener('click', e => {
    if (e.target === document.getElementById('modal-overlay')) closeModal();
  });

  // Next / Back
  document.getElementById('modal-next')?.addEventListener('click', goNext);
  document.getElementById('modal-back')?.addEventListener('click', goBack);

  // Channel options
  document.querySelectorAll('.channel-opt').forEach(opt => {
    opt.addEventListener('click', () => {
      document.querySelectorAll('.channel-opt').forEach(o => {
        o.classList.remove('border-indigo-500', 'bg-indigo-500/10');
        o.classList.add('border-slate-700', 'bg-slate-800');
      });
      opt.classList.remove('border-slate-700', 'bg-slate-800');
      opt.classList.add('border-indigo-500', 'bg-indigo-500/10');
      formState.channel = opt.getAttribute('data-channel') ?? '';

      const wrap = document.getElementById('channel-address-wrap');
      const label = document.getElementById('channel-address-label');
      const input = document.getElementById('channel-address');
      if (wrap) wrap.classList.remove('hidden');
      if (label) label.textContent = formState.channel === 'email' ? 'Email address' : 'Webhook URL';
      if (input) {
        input.placeholder = formState.channel === 'email' ? 'you@example.com' : 'https://your-service.com/webhook';
        input.type = formState.channel === 'email' ? 'email' : 'url';
        input.focus();
      }
    });
  });

  document.getElementById('channel-address')?.addEventListener('input', e => {
    formState.address = e.target.value;
  });

  // Delete dialog
  document.getElementById('delete-cancel')?.addEventListener('click', () => {
    document.getElementById('delete-overlay')?.classList.add('hidden');
    deleteTargetId = null;
  });

  document.getElementById('delete-confirm')?.addEventListener('click', async () => {
    if (!deleteTargetId) return;
    const btn = document.getElementById('delete-confirm');
    if (btn) { btn.textContent = 'Deleting…'; btn.setAttribute('disabled', 'true'); }

    try {
      await apiDeleteSubscription(deleteTargetId);
    } catch (err) {
      console.warn('[alerts] delete API failed (removing locally anyway):', err);
    }

    const subs = getSubscriptions().filter(s => s.id !== deleteTargetId);
    saveSubscriptions(subs);
    deleteTargetId = null;
    document.getElementById('delete-overlay')?.classList.add('hidden');
    if (btn) { btn.textContent = 'Delete'; btn.removeAttribute('disabled'); }
    renderSubscriptions();
  });

  // ── Boot ─────────────────────────────────────────────────────────────────
  renderSubscriptions();
  // Set default step dot styling
  updateStepUI(1);
</script>
