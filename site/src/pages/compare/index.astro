---
import Layout from '../../layouts/Layout.astro';
import providers from '../../data/providers';

type Provider = typeof providers[0];
type Model = Provider['models'][0];

const activeProviders = (providers as Provider[]).filter(p => p.status === 'active');

interface ModelFamily {
  id: string;
  name: string;
  category: string;
  description: string;
  tags?: string[];
  match: (modelId: string) => boolean;
}

const MODEL_FAMILIES: ModelFamily[] = [
  {
    id: 'gpt4',
    name: 'GPT-4o / GPT-4.1',
    category: 'OpenAI',
    description: 'OpenAI flagship series',
    tags: ['vision', 'function-call'],
    match: id => /gpt-4/i.test(id) && !/oss/i.test(id),
  },
  {
    id: 'gpt-oss',
    name: 'GPT-OSS',
    category: 'OpenAI',
    description: 'OpenAI open-weight models',
    match: id => /gpt.?oss/i.test(id),
  },
  {
    id: 'gemini',
    name: 'Gemini',
    category: 'Google',
    description: 'Gemini 2.5 / 3 series',
    tags: ['vision', 'thinking'],
    match: id => /gemini/i.test(id),
  },
  {
    id: 'gemma',
    name: 'Gemma 3',
    category: 'Google',
    description: 'Google open Gemma models',
    match: id => /gemma/i.test(id),
  },
  {
    id: 'llama3',
    name: 'Llama 3.x',
    category: 'Meta',
    description: 'Meta Llama 3 series',
    match: id => /llama.?3\.[0-3]/i.test(id) || /llama3\.[0-3]/i.test(id),
  },
  {
    id: 'llama4',
    name: 'Llama 4',
    category: 'Meta',
    description: 'Meta Llama 4 series',
    tags: ['vision'],
    match: id => /llama.?4/i.test(id),
  },
  {
    id: 'deepseek-v3',
    name: 'DeepSeek V3',
    category: 'DeepSeek',
    description: 'DeepSeek V3 chat / code',
    match: id => /deepseek.?v3/i.test(id) || /deepseek-v3/i.test(id),
  },
  {
    id: 'deepseek-r1',
    name: 'DeepSeek R1',
    category: 'DeepSeek',
    description: 'DeepSeek R1 reasoning',
    tags: ['thinking'],
    match: id => /deepseek.?r1/i.test(id),
  },
  {
    id: 'qwen3',
    name: 'Qwen 3',
    category: 'Alibaba',
    description: 'Alibaba Qwen 3 family',
    match: id => /qwen.?3/i.test(id),
  },
  {
    id: 'kimi',
    name: 'Kimi K2',
    category: 'Moonshot',
    description: 'Moonshot Kimi K2',
    match: id => /kimi.?k2/i.test(id),
  },
  {
    id: 'glm',
    name: 'GLM',
    category: 'Zhipu',
    description: 'Zhipu GLM series',
    match: id => /\bglm\b/i.test(id),
  },
  {
    id: 'minimax',
    name: 'MiniMax M2',
    category: 'MiniMax',
    description: 'MiniMax M2 series',
    match: id => /minimax/i.test(id),
  },
  {
    id: 'mistral',
    name: 'Mistral / Magistral',
    category: 'Mistral',
    description: 'Mistral conversational',
    match: id => /mistral|magistral|mixtral/i.test(id) && !/codestral/i.test(id),
  },
  {
    id: 'codestral',
    name: 'Codestral',
    category: 'Mistral',
    description: 'Mistral coding model',
    tags: ['code'],
    match: id => /codestral/i.test(id),
  },
  {
    id: 'phi',
    name: 'Phi-4',
    category: 'Microsoft',
    description: 'Microsoft Phi models',
    match: id => /\bphi\b/i.test(id),
  },
  {
    id: 'command',
    name: 'Command',
    category: 'Cohere',
    description: 'Cohere Command family',
    match: id => /command/i.test(id),
  },
];

interface CellData {
  models: Model[];
  bestRpd: number | null;
  bestRpm: number | null;
}

type Matrix = Record<string, Record<string, CellData>>;

const matrix: Matrix = {};
for (const family of MODEL_FAMILIES) {
  matrix[family.id] = {};
  for (const provider of activeProviders) {
    const matching = (provider.models as Model[]).filter(
      m => m.status !== 'deprecated' && family.match(m.id)
    );
    if (matching.length > 0) {
      const rpds = matching.map(m => m.rpd).filter((v): v is number => v !== null);
      const rpms = matching.map(m => m.rpm).filter((v): v is number => v !== null);
      matrix[family.id][provider.id] = {
        models: matching,
        bestRpd: rpds.length > 0 ? Math.max(...rpds) : null,
        bestRpm: rpms.length > 0 ? Math.max(...rpms) : null,
      };
    }
  }
}

const visibleFamilies = MODEL_FAMILIES.filter(f => Object.keys(matrix[f.id]).length > 0);

// Sort providers: most model-family coverage first
const sortedProviders = [...activeProviders].sort((a, b) => {
  const ca = visibleFamilies.filter(f => matrix[f.id][a.id]).length;
  const cb = visibleFamilies.filter(f => matrix[f.id][b.id]).length;
  return cb - ca;
});

const CATEGORY_COLORS: Record<string, string> = {
  OpenAI:    'bg-emerald-500/15 text-emerald-400 border-emerald-500/25',
  Google:    'bg-blue-500/15 text-blue-400 border-blue-500/25',
  Meta:      'bg-indigo-500/15 text-indigo-400 border-indigo-500/25',
  DeepSeek:  'bg-violet-500/15 text-violet-400 border-violet-500/25',
  Alibaba:   'bg-orange-500/15 text-orange-400 border-orange-500/25',
  Moonshot:  'bg-cyan-500/15 text-cyan-400 border-cyan-500/25',
  Zhipu:     'bg-sky-500/15 text-sky-400 border-sky-500/25',
  Mistral:   'bg-amber-500/15 text-amber-400 border-amber-500/25',
  MiniMax:   'bg-pink-500/15 text-pink-400 border-pink-500/25',
  Microsoft: 'bg-teal-500/15 text-teal-400 border-teal-500/25',
  Cohere:    'bg-rose-500/15 text-rose-400 border-rose-500/25',
};

const TAG_STYLE = 'inline-block px-1 py-0 text-[10px] rounded border border-slate-600 text-slate-500 font-mono leading-4';

function formatRpd(rpd: number | null): string {
  if (rpd === null) return '∞/d';
  if (rpd >= 1000) return `${(rpd / 1000).toFixed(0)}k/d`;
  return `${rpd}/d`;
}

// Serialise matrix for client-side tooltip
const matrixJson = JSON.stringify(
  Object.fromEntries(
    visibleFamilies.map(f => [
      f.id,
      Object.fromEntries(
        Object.entries(matrix[f.id]).map(([pid, cell]) => [
          pid,
          {
            models: cell.models.map(m => m.id),
            rpd: cell.bestRpd,
            rpm: cell.bestRpm,
          },
        ])
      ),
    ])
  )
);

const providersJson = JSON.stringify(
  sortedProviders.map(p => ({ id: p.id, name: p.name, status: p.status }))
);
---

<Layout
  title="Model Coverage Matrix — Free LLM APIs"
  description={`Which free LLM API supports which model family? Compare ${activeProviders.length} providers across ${visibleFamilies.length} model families including GPT-4, Gemini, Llama, DeepSeek, Qwen and more.`}
>
  <div class="max-w-7xl mx-auto px-4 md:px-6 lg:px-8 py-8">

    <!-- Header -->
    <div class="mb-5">
      <h1 class="text-2xl font-bold text-white mb-1">Model Coverage Matrix</h1>
      <p class="text-slate-400 text-sm">
        Which free API supports which model family?
        <span class="text-slate-500"> · {activeProviders.length} providers · {visibleFamilies.length} model families · hover a cell to see exact model IDs</span>
      </p>
    </div>

    <!-- Matrix table -->
    <div class="overflow-x-auto rounded-xl border border-slate-700/60">
      <table class="border-collapse text-sm" style="min-width: max-content;">
        <thead>
          <tr class="border-b border-slate-700 bg-slate-900/80">
            <!-- Top-left corner -->
            <th class="sticky left-0 z-20 bg-slate-900/95 backdrop-blur px-4 py-3 text-left min-w-[200px] w-[200px]">
              <span class="text-xs font-semibold text-slate-500 uppercase tracking-wider">Model Family</span>
            </th>
            {sortedProviders.map(provider => {
              const coverage = visibleFamilies.filter(f => matrix[f.id][provider.id]).length;
              return (
                <th class="px-3 py-3 text-center w-[110px] min-w-[110px]">
                  <div class="flex flex-col items-center gap-1.5">
                    <!-- Logo -->
                    <div class="w-7 h-7 rounded-lg bg-slate-800 flex items-center justify-center overflow-hidden flex-shrink-0">
                      {provider.logo ? (
                        <img
                          src={provider.logo}
                          alt={provider.name}
                          class="w-full h-full object-contain brightness-0 invert"
                          onerror="this.style.display='none';this.nextElementSibling.style.display='flex';"
                        />
                      ) : null}
                      <span class={provider.logo ? 'hidden text-xs font-bold text-slate-300' : 'text-xs font-bold text-slate-300'}>
                        {provider.name.charAt(0)}
                      </span>
                    </div>
                    <!-- Name + status -->
                    <div class="flex items-center gap-1">
                      <span
                        class="provider-name-header text-xs font-medium text-slate-300 truncate max-w-[80px]"
                        data-provider-id={provider.id}
                        title={provider.name}
                      >{provider.name}</span>
                      <span
                        class="provider-status-dot w-1.5 h-1.5 rounded-full flex-shrink-0 bg-green-500"
                        data-provider-id={provider.id}
                        title="active"
                      ></span>
                    </div>
                    <!-- Coverage count -->
                    <span class="text-[10px] text-slate-600 font-mono">{coverage}/{visibleFamilies.length}</span>
                  </div>
                </th>
              );
            })}
          </tr>
        </thead>

        <tbody>
          {visibleFamilies.map((family, rowIdx) => {
            const categoryStyle = CATEGORY_COLORS[family.category] ?? 'bg-slate-700/30 text-slate-400 border-slate-600/30';
            const supportCount = sortedProviders.filter(p => matrix[family.id][p.id]).length;
            return (
              <tr class={`border-t border-slate-800/60 hover:bg-slate-800/25 transition-colors duration-100 ${rowIdx % 2 === 1 ? 'bg-slate-900/30' : ''}`}>

                <!-- Family label (sticky) -->
                <td class={`sticky left-0 z-10 px-4 py-3 backdrop-blur ${rowIdx % 2 === 1 ? 'bg-slate-950/90' : 'bg-[#0f172a]/90'}`}>
                  <div class="flex flex-col gap-1">
                    <div class="flex items-center gap-2">
                      <span class="font-semibold text-slate-100 text-xs whitespace-nowrap">{family.name}</span>
                      <span class={`inline-flex items-center px-1.5 py-0 text-[10px] rounded border font-medium ${categoryStyle}`}>
                        {family.category}
                      </span>
                    </div>
                    <div class="flex items-center gap-1.5 flex-wrap">
                      <span class="text-[11px] text-slate-500">{family.description}</span>
                      {family.tags?.map(tag => (
                        <span class={TAG_STYLE}>{tag}</span>
                      ))}
                    </div>
                  </div>
                </td>

                <!-- Provider cells -->
                {sortedProviders.map(provider => {
                  const cell = matrix[family.id][provider.id];
                  return (
                    <td class="px-3 py-3 text-center">
                      {cell ? (
                        <button
                          class="matrix-cell inline-flex flex-col items-center gap-0.5 px-2 py-1.5 rounded-lg bg-green-500/10 border border-green-500/20 hover:bg-green-500/20 hover:border-green-500/35 transition-all duration-150 cursor-pointer w-full"
                          data-family={family.id}
                          data-provider={provider.id}
                          aria-label={`${family.name} on ${provider.name}`}
                        >
                          <span class="text-green-400 text-xs font-semibold leading-none">✓</span>
                          <span class="text-[10px] text-green-400/70 font-mono leading-none">{formatRpd(cell.bestRpd)}</span>
                        </button>
                      ) : (
                        <span class="text-slate-800 text-xs">—</span>
                      )}
                    </td>
                  );
                })}
              </tr>
            );
          })}

          <!-- Coverage totals row -->
          <tr class="border-t border-slate-700/60 bg-slate-900/60">
            <td class="sticky left-0 z-10 bg-slate-900/95 backdrop-blur px-4 py-2.5">
              <span class="text-xs font-semibold text-slate-400 uppercase tracking-wider">Families covered</span>
            </td>
            {sortedProviders.map(provider => {
              const count = visibleFamilies.filter(f => matrix[f.id][provider.id]).length;
              const pct = Math.round((count / visibleFamilies.length) * 100);
              return (
                <td class="px-3 py-2.5 text-center">
                  <div class="flex flex-col items-center gap-1">
                    <span class="text-xs font-bold text-slate-200">{count}</span>
                    <div class="w-12 h-1 rounded-full bg-slate-700 overflow-hidden">
                      <div
                        class="h-full rounded-full bg-green-500/70"
                        style={`width: ${pct}%`}
                      ></div>
                    </div>
                  </div>
                </td>
              );
            })}
          </tr>
        </tbody>
      </table>
    </div>

    <!-- Legend -->
    <div class="mt-4 flex flex-wrap items-center gap-4 text-xs text-slate-500">
      <div class="flex items-center gap-1.5">
        <span class="inline-flex items-center px-2 py-0.5 rounded-lg bg-green-500/10 border border-green-500/20 text-green-400 font-semibold text-[10px]">✓ 1k/d</span>
        <span>Supported — best daily quota</span>
      </div>
      <div class="flex items-center gap-1.5">
        <span class="inline-flex items-center px-2 py-0.5 rounded-lg bg-green-500/10 border border-green-500/20 text-green-400 font-semibold text-[10px]">✓ ∞/d</span>
        <span>Supported — no daily limit documented</span>
      </div>
      <div class="flex items-center gap-1.5">
        <span class="text-slate-700">—</span>
        <span>Not available</span>
      </div>
    </div>

  </div>

  <!-- Tooltip -->
  <div
    id="matrix-tooltip"
    class="hidden fixed z-50 pointer-events-none"
    role="tooltip"
  >
    <div class="bg-slate-900 border border-slate-600 rounded-xl shadow-2xl p-3 w-60">
      <div id="tt-header" class="flex items-center justify-between mb-2">
        <span id="tt-provider" class="text-xs font-semibold text-slate-200"></span>
        <span id="tt-family" class="text-[10px] text-slate-500"></span>
      </div>
      <div id="tt-models" class="space-y-0.5 mb-2"></div>
      <div id="tt-limits" class="flex gap-3 pt-2 border-t border-slate-700/50 text-[10px] font-mono text-slate-400"></div>
    </div>
  </div>

<script define:vars={{ matrixJson, providersJson }}>
  const MATRIX = JSON.parse(matrixJson);
  const PROVIDERS = JSON.parse(providersJson);
  const providerMap = Object.fromEntries(PROVIDERS.map(p => [p.id, p]));

  // ── Tooltip ───────────────────────────────────────────────────────────────────
  const tooltip = document.getElementById('matrix-tooltip');
  const ttProvider = document.getElementById('tt-provider');
  const ttFamily = document.getElementById('tt-family');
  const ttModels = document.getElementById('tt-models');
  const ttLimits = document.getElementById('tt-limits');

  let hideTimer = null;

  function showTooltip(btn, familyId, providerId) {
    clearTimeout(hideTimer);
    const cell = MATRIX[familyId]?.[providerId];
    const provider = providerMap[providerId];
    if (!cell || !provider || !tooltip) return;

    if (ttProvider) ttProvider.textContent = provider.name;
    if (ttFamily) ttFamily.textContent = familyId;

    if (ttModels) {
      const shown = cell.models.slice(0, 5);
      const extra = cell.models.length - shown.length;
      ttModels.innerHTML = shown
        .map(id => `<div class="text-[11px] text-slate-300 font-mono truncate" title="${id}">${id}</div>`)
        .join('') + (extra > 0 ? `<div class="text-[10px] text-slate-500 mt-0.5">+${extra} more</div>` : '');
    }

    if (ttLimits) {
      const rpm = cell.rpm !== null ? `${cell.rpm} RPM` : '— RPM';
      const rpd = cell.rpd !== null ? `${cell.rpd >= 1000 ? (cell.rpd / 1000).toFixed(0) + 'k' : cell.rpd} RPD` : '∞ RPD';
      ttLimits.innerHTML = `<span>${rpm}</span><span>${rpd}</span>`;
    }

    tooltip.classList.remove('hidden');
    positionTooltip(btn);
  }

  function positionTooltip(btn) {
    if (!tooltip) return;
    const rect = btn.getBoundingClientRect();
    const tW = 240, tH = 160;
    let left = rect.left + rect.width / 2 - tW / 2;
    let top = rect.top - tH - 8 + window.scrollY;

    // Flip below if not enough space above
    if (rect.top < tH + 16) top = rect.bottom + 8 + window.scrollY;
    // Clamp horizontally
    left = Math.max(8, Math.min(left, window.innerWidth - tW - 8));

    tooltip.style.left = `${left}px`;
    tooltip.style.top = `${top}px`;
  }

  function hideTooltip() {
    hideTimer = setTimeout(() => tooltip?.classList.add('hidden'), 120);
  }

  document.querySelectorAll('.matrix-cell').forEach(btn => {
    btn.addEventListener('mouseenter', () => {
      const fid = btn.getAttribute('data-family');
      const pid = btn.getAttribute('data-provider');
      if (fid && pid) showTooltip(btn, fid, pid);
    });
    btn.addEventListener('mouseleave', hideTooltip);
    btn.addEventListener('focus', () => {
      const fid = btn.getAttribute('data-family');
      const pid = btn.getAttribute('data-provider');
      if (fid && pid) showTooltip(btn, fid, pid);
    });
    btn.addEventListener('blur', hideTooltip);
  });

  tooltip?.addEventListener('mouseenter', () => clearTimeout(hideTimer));
  tooltip?.addEventListener('mouseleave', hideTooltip);

  // ── Live status update ───────────────────────────────────────────────────────
  const STATUS_DOT: Record<string, string> = {
    active:   'bg-green-500',
    degraded: 'bg-yellow-500',
    dead:     'bg-red-500',
    unknown:  'bg-slate-600',
  };

  document.addEventListener('status-updated', (e) => {
    const data = e.detail;
    data.providers?.forEach(({ id, status }) => {
      document.querySelectorAll(`.provider-status-dot[data-provider-id="${id}"]`).forEach(dot => {
        dot.className = `provider-status-dot w-1.5 h-1.5 rounded-full flex-shrink-0 ${STATUS_DOT[status] ?? STATUS_DOT.unknown}`;
        dot.title = status;
      });
    });
  });
</script>

</Layout>
